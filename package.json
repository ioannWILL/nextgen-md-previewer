{
  "name": "nextgen-md-previewer",
  "displayName": "NextGen .md Previewer",
  "description": "A WYSIWYG markdown editor for VS Code. Edit rendered markdown directly without switching to raw mode.",
  "version": "0.3.0",
  "publisher": "IvanVilchavskyi",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ioannWILL/nextgen-md-previewer.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "markdown",
    "wysiwyg",
    "preview",
    "editor",
    "md"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "nextgenMdPreviewer.open",
        "title": "Preview with NextGen .md Previewer"
      }
    ],
    "menus": {
      "editor/title/context": [
        {
          "command": "nextgenMdPreviewer.open",
          "when": "resourceLangId == markdown",
          "group": "1_open"
        }
      ]
    },
    "configuration": {
      "title": "NextGen .md Previewer",
      "properties": {
        "nextgenMdPreviewer.autoSaveDelay": {
          "type": "number",
          "default": 1000,
          "minimum": 100,
          "maximum": 10000,
          "description": "Delay in milliseconds before auto-saving changes to the file"
        },
        "nextgenMdPreviewer.previewLocation": {
          "type": "string",
          "enum": [
            "sameTab",
            "sideBySide"
          ],
          "default": "sameTab",
          "enumDescriptions": [
            "Open preview in a new tab in the same editor group",
            "Open preview in a new editor group to the side"
          ],
          "description": "Where to open the preview panel"
        },
        "nextgenMdPreviewer.autoOpen": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open preview when a markdown file is opened"
        },
        "nextgenMdPreviewer.toolbar.visible": {
          "type": "boolean",
          "default": true,
          "description": "Show the formatting toolbar"
        },
        "nextgenMdPreviewer.features.math": {
          "type": "boolean",
          "default": true,
          "description": "Enable LaTeX math equation rendering"
        },
        "nextgenMdPreviewer.features.mermaid": {
          "type": "boolean",
          "default": true,
          "description": "Enable Mermaid diagram rendering"
        },
        "nextgenMdPreviewer.images.folder": {
          "type": "string",
          "default": "assets",
          "description": "Folder name for uploaded images (relative to document)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "lint": "eslint src/",
    "test": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^9.x",
    "@types/node": "^20.x",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.x",
    "eslint": "^9.x",
    "typescript": "^5.x",
    "typescript-eslint": "^8.x",
    "vitest": "^1.x"
  },
  "dependencies": {
    "@milkdown/core": "^7.x",
    "@milkdown/ctx": "^7.x",
    "@milkdown/plugin-diagram": "^7.x",
    "@milkdown/plugin-history": "^7.18.0",
    "@milkdown/plugin-listener": "^7.x",
    "@milkdown/plugin-math": "^7.x",
    "@milkdown/preset-commonmark": "^7.x",
    "@milkdown/preset-gfm": "^7.x",
    "katex": "^0.16.x",
    "mermaid": "^10.x",
    "prismjs": "^1.29.x"
  }
}
